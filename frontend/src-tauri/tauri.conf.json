{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Svarka Weld Messenger",
  "version": "0.1.0",
  "identifier": "ru.svarkaweld.messenger.desktop",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run dev -- --hostname 127.0.0.1 --port 1420",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Svarka Weld Messenger",
        "url": "https://chat.svarka-weld.ru",
        "width": 1440,
        "height": 960,
        "minWidth": 1024,
        "minHeight": 720,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
